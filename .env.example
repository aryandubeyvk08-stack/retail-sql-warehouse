# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your own values. .env is gitignored.
# ---------------------------------------------------------------------------

# --- Option A: Neon (free tier, no credit card) ----------------------------
# Neon Console -> your project -> "Connect" button -> copy the connection string.
# Leave "Connection pooling" ON (the hostname then contains "-pooler").
#
# It looks like this:
#   postgresql://neondb_owner:PASSWORD@ep-cool-name-a1b2c3-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
#
# Paste it as-is — config.py rewrites the scheme to postgresql+psycopg:// for you.
# Neon requires SSL, so keep sslmode/channel_binding in the string.

# --- Option B: Supabase ----------------------------------------------------
# Project Settings -> Database -> Connection string -> URI (use Session Pooler).
#   postgresql://postgres.abcdefghijklm:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# --- Option C: AWS RDS -----------------------------------------------------
#   postgresql://postgres:PASSWORD@mydb.xxxxx.ap-south-1.rds.amazonaws.com:5432/retail

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Path to the raw Superstore CSV, relative to the project root.
# Using the generated sample instead? Point this at data/raw/sample_superstore.csv
RAW_CSV_PATH=data/raw/superstore.csv

# Rows per INSERT batch. Lower it if a long-distance connection times out.
LOAD_CHUNK_SIZE=1000
